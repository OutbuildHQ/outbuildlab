---
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-top">
    <div class="footer-brand">
      <Logo />
      <p>Outbuild Lab —<br />AI-native product studio.</p>
    </div>
    <nav class="footer-nav" aria-label="Footer">
      <div>
        <h4>Sitemap</h4>
        <a href="/work" data-hover>Work</a>
        <a href="/studio" data-hover>Studio</a>
        <a href="/services" data-hover>Services</a>
        <a href="/lab" data-hover>The Lab</a>
        <a href="/founding" data-hover>Founding Partners</a>
        <a href="/contact" data-hover>Contact</a>
      </div>
      <div>
        <h4>Socials</h4>
        <a href="#" data-hover>X / Twitter</a>
        <a href="#" data-hover>LinkedIn</a>
        <a href="#" data-hover>Dribbble</a>
        <a href="#" data-hover>GitHub</a>
      </div>
    </nav>
  </div>
  <div class="footer-bottom">
    <span>© {year} Outbuild Lab. All rights reserved. · RC 8076384</span>
    <span id="localTime">LAGOS — 00:00</span>
    <a href="#top" class="back-top" data-hover>BACK TO TOP ↑</a>
  </div>
</footer>
