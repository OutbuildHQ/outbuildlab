---
const examples = [
  "An AI study buddy that quizzes students on their own notes",
  "A marketplace for hiring local private chefs",
  "An invoicing app for freelancers who hate invoicing",
];
---
<div class="lab-tool reveal" id="buildPlanner">
  <form class="lab-form" id="planForm" novalidate>
    <label class="lab-label" for="ideaInput">Describe your product in a sentence</label>
    <div class="lab-input-row">
      <textarea
        id="ideaInput"
        name="idea"
        class="lab-input"
        rows="2"
        maxlength="600"
        placeholder="e.g. An app that turns voice notes into organised to-do lists…"
        required></textarea>
      <button type="submit" class="btn-accent lab-submit" data-hover>
        <span class="lab-submit-label">Generate plan ↗</span>
      </button>
    </div>
    <div class="lab-examples" aria-label="Example ideas">
      <span>Try:</span>
      {examples.map((ex) => (
        <button type="button" class="lab-chip" data-example={ex} data-hover>{ex}</button>
      ))}
    </div>
  </form>

  <div class="lab-output" id="planOutput" aria-live="polite"></div>
</div>

<script>
  import { generatePlan, SIGNAL_LABELS, type BuildPlan } from "../../lib/buildPlan";

  const root = document.getElementById("buildPlanner");
  if (root) {
    const form = root.querySelector<HTMLFormElement>("#planForm")!;
    const input = root.querySelector<HTMLTextAreaElement>("#ideaInput")!;
    const output = root.querySelector<HTMLDivElement>("#planOutput")!;
    const submit = form.querySelector<HTMLButtonElement>(".lab-submit")!;
    const submitLabel = submit.querySelector<HTMLElement>(".lab-submit-label")!;

    root.querySelectorAll<HTMLButtonElement>(".lab-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        input.value = chip.dataset.example || "";
        input.focus();
        form.requestSubmit();
      });
    });

    const esc = (s: string) =>
      s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c] as string));

    async function getPlan(idea: string): Promise<BuildPlan> {
      // Prefer the server route (real model when a key is set). If it's
      // absent (static deploy) or errors, fall back to the local generator.
      try {
        const res = await fetch("/api/build-plan", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ idea }),
        });
        if (res.ok) return (await res.json()) as BuildPlan;
      } catch {
        /* network/static — fall through */
      }
      return generatePlan(idea);
    }

    function render(plan: BuildPlan) {
      const signalChips = (plan.signals || [])
        .map((s) => `<span class="plan-signal">${esc(SIGNAL_LABELS[s] || s)}</span>`)
        .join("");

      output.innerHTML = `
        <article class="plan">
          <header class="plan-head">
            <div class="plan-head-meta">
              <span class="plan-kicker">Build plan · ${plan.source === "ai" ? "generated by Claude" : "Outbuild Lab engine"}</span>
              <div class="plan-signals">${signalChips}</div>
            </div>
            <p class="plan-oneliner">${esc(plan.oneLiner)}</p>
            <p class="plan-type">Shape: <strong>${esc(plan.type)}</strong></p>
          </header>

          <div class="plan-grid">
            <section class="plan-block" style="--i:0">
              <h4>MVP scope</h4>
              <ul class="plan-scope">
                ${plan.scope.map((s) => `<li>${esc(s)}</li>`).join("")}
              </ul>
            </section>

            <section class="plan-block" style="--i:1">
              <h4>Recommended stack</h4>
              <dl class="plan-stack">
                ${plan.stack
                  .map((s) => `<div><dt>${esc(s.label)}</dt><dd>${esc(s.value)}</dd></div>`)
                  .join("")}
              </dl>
            </section>

            <section class="plan-block plan-block--wide" style="--i:2">
              <h4>The timeline</h4>
              <ol class="plan-timeline">
                ${plan.timeline
                  .map(
                    (p) => `
                  <li>
                    <span class="pt-day">${esc(p.day)}</span>
                    <span class="pt-label">${esc(p.label)}</span>
                    <span class="pt-detail">${esc(p.detail)}</span>
                  </li>`
                  )
                  .join("")}
              </ol>
            </section>

            <section class="plan-block plan-block--wide" style="--i:3">
              <h4>What we'd pressure-test</h4>
              <ul class="plan-risks">
                ${plan.risks.map((r) => `<li>${esc(r)}</li>`).join("")}
              </ul>
            </section>
          </div>

          <footer class="plan-foot">
            <p>This is a 20-second machine sketch. The real thing starts with a conversation.</p>
            <button type="button" class="btn-accent" data-open-modal data-hover>Build this for real ↗</button>
          </footer>
        </article>`;

      // the injected CTA's [data-open-modal] is handled by the delegated
      // click listener in app.js — no per-render binding needed.
      requestAnimationFrame(() => output.querySelector(".plan")?.classList.add("is-in"));
    }

    let busy = false;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const idea = input.value.trim();
      if (idea.length < 3 || busy) return;

      busy = true;
      submit.disabled = true;
      submitLabel.textContent = "Generating…";
      output.classList.add("is-loading");
      output.innerHTML = `
        <div class="plan-loading">
          <span class="pl-bar"></span><span class="pl-bar"></span><span class="pl-bar"></span>
          <p>Reading the brief, generating the plan…</p>
        </div>`;

      const plan = await getPlan(idea);
      // small floor so the loader doesn't flash on the instant local path
      await new Promise((r) => setTimeout(r, 450));

      output.classList.remove("is-loading");
      render(plan);

      submit.disabled = false;
      submitLabel.textContent = "Regenerate ↗";
      busy = false;
    });
  }
</script>
