---
// Wired to Web3Forms (free). Submissions email straight to the address
// configured for this access key in the Web3Forms dashboard. The access
// key is public by design (safe to commit). Submit is AJAX'd in app.js.
const WEB3FORMS_KEY = "395aa1ef-c9c1-4cb7-9b71-dfd618cdfcc8";
---
<form class="ob-form" method="POST" action="https://api.web3forms.com/submit">
  <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
  <input type="hidden" name="subject" value="New lead — outbuildlab.com" />
  <input type="hidden" name="from_name" value="Outbuild Lab" />
  <!-- honeypot: bots tick this; it's hidden from humans -->
  <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" style="display:none !important" />
  <div class="field">
    <label>Name</label>
    <input type="text" name="name" placeholder="Ada Lovelace" required />
  </div>
  <div class="field">
    <label>Email</label>
    <input type="email" name="email" placeholder="ada@company.com" required />
  </div>
  <div class="field">
    <label>Company / Project</label>
    <input type="text" name="company" placeholder="Acme Inc." />
  </div>
  <div class="field">
    <label>Budget</label>
    <select name="budget">
      <option value="">Select a range</option>
      <option>Under $10k</option>
      <option>$10k – $25k</option>
      <option>$25k – $50k</option>
      <option>$50k+</option>
      <option>Founding partner slot</option>
    </select>
  </div>
  <div class="field field--full">
    <label>What are we building?</label>
    <textarea name="message" placeholder="The product, the problem, the deadline — give us the shape of it." required></textarea>
  </div>
  <div class="form-foot">
    <button type="submit" class="btn-accent" data-hover>Send it ↗</button>
    <span class="form-status" role="status"></span>
  </div>
</form>
