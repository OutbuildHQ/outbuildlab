---
import WorkGrid from "../WorkGrid.astro";
---
<section class="work section" id="work">
  <div class="section-head">
    <span class="section-label">03 — Selected Builds</span>
    <span class="section-rule"></span>
    <a href="/work" class="section-more" data-hover>All builds ↗</a>
  </div>

  <h2 class="section-title reveal">Proof,<br /><em class="stroke">not promises</em></h2>

  <p class="work-intro reveal">
    No borrowed logos, no inflated case studies. Every build below was
    concepted, designed and engineered with AI — then directed to ship
    quality by us. Proof of the method, and the pace, while the first client
    stories are written.
  </p>

  <WorkGrid mode="teaser" />
</section>
