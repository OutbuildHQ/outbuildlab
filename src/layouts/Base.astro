---
import "../styles/fonts.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProjectModal from "../components/ProjectModal.astro";

interface Props {
  title?: string;
  description?: string;
  robots?: string;
  breadcrumbs?: { name: string; url: string }[];
}

const {
  title = "Outbuild Lab — AI-Native Product Design & Development Studio",
  description = "Outbuild Lab is an AI-native product studio. We design and build with AI at full power, and bring the taste and judgment that turn model output into products people trust — strategy to shipped, in days.",
  robots = "index, follow",
  breadcrumbs,
} = Astro.props;

const favicon =
  'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><rect width="32" height="32" rx="7" fill="%230B0B0C"/><path d="M19.26 6.54 A10 10 0 1 0 25.46 12.74" fill="none" stroke="%23D7FF3E" stroke-width="2.5" stroke-linecap="round"/><rect x="21.07" y="6.93" width="4" height="4" rx="0.8" fill="%23D7FF3E" transform="rotate(45 23.07 8.93)"/></svg>';

// Absolute URLs for social cards (Astro.site = https://outbuildlab.com)
const ogImage = new URL("/og.png", Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Structured data (@graph): Organization + WebSite, plus BreadcrumbList
// on pages that pass `breadcrumbs`. Helps search engines model the studio
// and render rich results.
const site = Astro.site?.href;
const graph: Record<string, unknown>[] = [
  {
    "@type": "Organization",
    "@id": `${site}#org`,
    name: "Outbuild Lab",
    url: site,
    logo: new URL("/icon-512.png", Astro.site).href,
    image: ogImage,
    description:
      "AI-native product studio. We design and build with AI at full power, and bring the taste and judgment that turn model output into products people trust.",
    email: "hello@outbuildlab.com",
    foundingDate: "2026",
    address: { "@type": "PostalAddress", addressLocality: "Lagos", addressCountry: "NG" },
    areaServed: "Worldwide",
    knowsAbout: [
      "Product strategy",
      "Product design",
      "Software engineering",
      "AI product engineering",
      "Brand and motion",
    ],
    identifier: { "@type": "PropertyValue", name: "RC Number", value: "8076384" },
  },
  {
    "@type": "WebSite",
    "@id": `${site}#website`,
    name: "Outbuild Lab",
    url: site,
    publisher: { "@id": `${site}#org` },
  },
];
if (breadcrumbs?.length) {
  graph.push({
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbs.map((b, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: b.name,
      item: b.url,
    })),
  });
}
const jsonLd = { "@context": "https://schema.org", "@graph": graph };
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="google-site-verification" content="EOw1ypYuzzPOQ8HzV_PeFxccWwJqsjj0vk6cSQFXmwc" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Outbuild Lab" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Outbuild Lab — Outbuild the timeline" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#0b0b0c" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
    <link rel="icon" href={favicon} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- self-hosted fonts (see src/styles/fonts.css); preload the two most
         above-the-fold faces to minimise swap flash -->
    <link rel="preload" href="/fonts/clash-display-600.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/satoshi-400.woff2" as="font" type="font/woff2" crossorigin />

    <!-- theme bootstrap: runs before paint so there's no flash -->
    <script is:inline>
      document.documentElement.dataset.theme =
        localStorage.getItem("ob-theme") || "dark";
    </script>
  </head>
  <body id="top">
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="scroll-progress" aria-hidden="true"></div>
    <div class="cursor-dot" id="cursorDot"></div>
    <div class="cursor-ring" id="cursorRing"><span>VIEW</span></div>
    <div class="grain" aria-hidden="true"></div>

    <Header />

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <Footer />
    <ProjectModal />

    <script src="../scripts/app.js"></script>
  </body>
</html>
