---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProjectModal from "../components/ProjectModal.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Outbuild Lab — AI-Native Product Studio",
  description = "Outbuild Lab is an AI-native product studio. We design and build with AI at full power, and bring the taste and judgment that turn model output into products people trust — strategy to shipped, in days.",
} = Astro.props;

const favicon =
  'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><rect width="32" height="32" rx="7" fill="%230B0B0C"/><path d="M19.26 6.54 A10 10 0 1 0 25.46 12.74" fill="none" stroke="%23D7FF3E" stroke-width="2.5" stroke-linecap="round"/><rect x="21.07" y="6.93" width="4" height="4" rx="0.8" fill="%23D7FF3E" transform="rotate(45 23.07 8.93)"/></svg>';

// Absolute URLs for social cards (Astro.site = https://outbuildlab.com)
const ogImage = new URL("/og.png", Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Outbuild Lab" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Outbuild Lab — Outbuild the timeline" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#0b0b0c" />
    <link rel="icon" href={favicon} />

    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&f[]=satoshi@400,500,700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- theme bootstrap: runs before paint so there's no flash -->
    <script is:inline>
      document.documentElement.dataset.theme =
        localStorage.getItem("ob-theme") || "dark";
    </script>
  </head>
  <body id="top">
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="scroll-progress" aria-hidden="true"></div>
    <div class="cursor-dot" id="cursorDot"></div>
    <div class="cursor-ring" id="cursorRing"><span>VIEW</span></div>
    <div class="grain" aria-hidden="true"></div>

    <Header />

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <Footer />
    <ProjectModal />

    <script src="../scripts/app.js"></script>
  </body>
</html>
